<ul class="editgrid-listgroup divide-y divide-border rounded-lg border border-border
    {{ ctx.component.striped ? '[&_li:nth-child(odd)]:bg-muted/50' : ''}}
    {{ ctx.component.bordered ? '[&_li]:border [&_li]:border-border' : ''}}
    {{ ctx.component.hover ? '[&_li:hover]:bg-muted' : ''}}
    {{ ctx.component.condensed ? '[&_li]:px-2 [&_li]:py-1' : ''}}
    ">
  {% if (ctx.header) { %}
  <li class="px-4 py-3 list-group-header">
    {{ctx.header}}
  </li>
  {% } %}
  {% ctx.rows.forEach(function(row, rowIndex) { %}
  <li class="px-4 py-3" ref="{{ctx.ref.row}}">
    {{row}}
    {% if (ctx.openRows[rowIndex] && !ctx.readOnly) { %}
    <div class="editgrid-actions">
      <button class="inline-flex items-center justify-center gap-2 rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium shadow-sm hover:bg-primary/90 transition-colors" ref="{{ctx.ref.saveRow}}">{{ctx.t(ctx.component.saveRow || 'save', { _userInput: !!ctx.component.saveRow })}}</button>
      {% if (ctx.component.removeRow) { %}
      <button class="inline-flex items-center justify-center gap-2 rounded-md bg-destructive text-destructive-foreground px-4 py-2 text-sm font-medium shadow-sm hover:bg-destructive/90 transition-colors" ref="{{ctx.ref.cancelRow}}">{{ctx.t(ctx.component.removeRow || 'cancel', { _userInput: !!ctx.component.removeRow })}}</button>
      {% } %}
    </div>
    {% } %}
    <div class="text-destructive">
      <div class="editgrid-row-error text-sm text-destructive">
        {{ctx.errors[rowIndex]}}
      </div>
    </div>
  </li>
  {% }) %}
  {% if (ctx.footer) { %}
  <li class="px-4 py-3 list-group-footer">
    {{ctx.footer}}
  </li>
  {% } %}
</ul>
