<div class="formio builder grid grid-cols-12 gap-0 formbuilder">
  <div class="col-span-2 formcomponents">
    {{ctx.sidebar}}
  </div>
  <div class="col-span-10 formarea">
    <ol class="flex flex-wrap items-center gap-2 mb-4 wizard-pages">
      {% ctx.pages.forEach(function(page, pageIndex) { %}
      <li>
        <span title="{{page.title}}" class="mr-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold {% if (pageIndex === ctx.self.page) { %}bg-primary text-primary-foreground{% } else { %}bg-blue-500/10 text-blue-700 dark:text-blue-400{% } %} wizard-page-label" ref="gotoPage">{{page.title}}</span>
      </li>
      {% }) %}
      <li class="wizard-add-page">
        <span title="{{ctx.t('createPage')}}" class="mr-2 inline-flex items-center rounded-full bg-green-500/10 text-green-700 dark:text-green-400 px-2.5 py-0.5 text-xs font-semibold wizard-page-label" ref="addPage">
          <i class="{{ctx.iconClass('plus')}}"></i> {{ctx.t('page')}}
        </span>
      </li>
    </ol>
    <div ref="form">
      {{ctx.form}}
    </div>
  </div>
</div>
