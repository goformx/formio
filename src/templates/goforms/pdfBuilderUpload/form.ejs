<div class="pdf-upload formio-component-file">
  <h3 class="label">{{ctx.t('uploadPdfFile')}}</h3>
  <input type="file" style="opacity: 0; position: absolute;" tabindex="-1" accept=".pdf" ref="hiddenFileInputElement">
  <div class="fileSelector" ref="fileDrop">
    <span ref="dragDropText">
      <i class="{{ctx.iconClass('cloud-upload')}}"></i>{{ctx.t('dropToStart')}} <a href="#" ref="fileBrowse" class="browse">{{ctx.t('browse')}}</a>
    </span>
    <div class="h-2 w-full overflow-hidden rounded-full bg-muted pdf-progress" ref="uploadProgressWrapper" style="display:none;">
      <div class="h-full bg-primary transition-all" ref="uploadProgress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
  </div>
  <div class="rounded-md border border-destructive/50 bg-destructive/10 px-4 py-3 text-sm text-destructive" ref="uploadError">

  </div>
</div>
