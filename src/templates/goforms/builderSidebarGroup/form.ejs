<div class="border-b border-border form-builder-panel" ref="group-panel-{{ctx.groupKey}}">
  <div class="form-builder-group-header p-0" id="heading-{{ctx.groupKey}}">
    <h5 class="mb-0 mt-0 grid">
      <button
        class="inline-flex w-full items-center justify-start px-3 py-2 text-sm font-medium text-foreground hover:bg-accent transition-colors builder-group-button"
        type="button"
        aria-expanded="{{ctx.group.default}}"
        aria-controls="group-{{ctx.groupKey}}"
        ref="sidebar-anchor"
      >
        {{ctx.t(ctx.group.title, { _userInput: true })}}
      </button>
    </h5>
  </div>
  <div
    id="group-{{ctx.groupKey}}"
    class="overflow-hidden transition-all{{ctx.group.default ? '' : ' hidden'}}"
    data-default="{{ctx.group.default}}"
    aria-labelledby="heading-{{ctx.groupKey}}"
    ref="sidebar-group"
  >
    <div id="group-container-{{ctx.groupKey}}" class="grid gap-1 no-drop p-2 w-full" ref="sidebar-container">
      {% if (ctx.group.componentOrder.length || ctx.subgroups.length) { %}
        {% !ctx.group.componentOrder || ctx.group.componentOrder.forEach(function(componentKey) { %}
          <span
            ref="sidebar-component"
            data-group="{{ctx.groupKey}}"
            data-key="{{ctx.group.components[componentKey].key}}"
            data-type="{{ctx.group.components[componentKey].schema.type}}"
            class="inline-flex items-center justify-start gap-1 rounded-md border border-primary text-primary bg-transparent px-3 py-1.5 text-sm font-medium hover:bg-primary hover:text-primary-foreground transition-colors formcomponent drag-copy m-0"
            tabindex="{{ctx.keyboardActionsEnabled ? 0 : -1}}"
          >
            {% if (ctx.group.components[componentKey].icon) { %}
              <i class="{{ctx.iconClass(ctx.group.components[componentKey].icon)}} mr-1"></i>
            {% } %}
            {{ctx.t(ctx.group.components[componentKey].title, { _userInput: true })}}
          </span>
        {% }) %}
        {{ctx.subgroups.join('')}}
      {% } else { %}
        <div>{{ctx.t('noMatchesFound')}}</div>
      {% } %}
    </div>
  </div>
</div>
