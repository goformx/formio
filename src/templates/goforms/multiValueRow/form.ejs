<tr ref="row">
  <td>
    {{ctx.element}}
  </td>
  {% if (!ctx.disabled) { %}
  <td>
    <button type="button" class="inline-flex items-center justify-center gap-2 rounded-md bg-secondary text-secondary-foreground px-4 py-2 text-sm font-medium shadow-sm hover:bg-secondary/80 transition-colors" ref="removeRow">
      <i class="{{ctx.iconClass('remove-circle')}}"></i>
    </button>
  </td>
  {% } %}
</tr>
