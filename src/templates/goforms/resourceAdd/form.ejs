<table class="w-full text-sm border border-border [&_th]:border [&_th]:border-border [&_td]:border [&_td]:border-border">
  <tbody>
    <tr>
      <td>
        {{ctx.element}}
      </td>
    </tr>
    <tr>
      <td colspan="2">
        <button class="inline-flex items-center justify-center gap-2 rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium shadow-sm hover:bg-primary/90 transition-colors formio-button-add-resource" ref="addResource">
          <i class="{{ctx.iconClass('plus')}}"></i>
          {{ctx.t(ctx.component.addResourceLabel || 'addResource', { _userInput: !!ctx.component.addResourceLabel })}}
        </button>
      </td>
    </tr>
  </tbody>
</table>
